<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}NewsHub{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="d-flex align-items-center gap-2 me-2">
        <span class="badge bg-secondary">$ {{ usd_rate|number_format(2) }} ₴</span>
        <span class="badge bg-warning text-dark">₿ {{ btc_price|number_format(0, '.', ',') }}$</span>
    </div>
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">NewsHub</a>
        <div class="navbar-nav ms-auto d-flex flex-row align-items-center gap-3">
            <a class="nav-link" href="{{ path('app_article_index') }}">Всі статті</a>
            {% for category in categories %}
                <a class="nav-link" href="{{ path('app_category_show', {slug: category.slug}) }}">
                    {{ category.name }}
                </a>
            {% endfor %}

            {% if app.user %}
                <span class="nav-link text-white">{{ app.user.username }}</span>
                <a class="btn btn-outline-light btn-sm" href="{{ path('app_logout') }}">Вийти</a>
            {% else %}
                <a class="btn btn-outline-light btn-sm" href="{{ path('app_login') }}">Увійти</a>
                <a class="btn btn-light btn-sm" href="{{ path('app_register') }}">Реєстрація</a>
            {% endif %}
        </div>
    </div>
</nav>

<div class="container">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success mt-3">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger mt-3">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('verify_email_error') %}
        <div class="alert alert-danger mt-3">{{ message }}</div>
    {% endfor %}

    {% block body %}{% endblock %}
</div>

<footer class="bg-dark text-white text-center py-3 mt-5">
    <p class="mb-0">© {{ "now"|date("Y") }} NewsHub</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>