<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}NewsHub{% endblock %}</title>

    {# Bootstrap CSS #}
    <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            rel="stylesheet"
    >

    {# Optional custom styles #}
    <style>
        body {
            background-color: #f8f9fa;
        }

        .navbar-brand {
            font-weight: 700;
        }

        .article-card {
            transition: transform 0.2s ease;
        }

        .article-card:hover {
            transform: translateY(-2px);
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>

<body class="d-flex flex-column min-vh-100">

{# NAVBAR #}
<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container">

        {# Logo #}
        <a class="navbar-brand" href="{{ path('app_home') }}">
            NewsHub
        </a>

        {# Mobile rates #}
        <div class="d-flex align-items-center gap-2 d-lg-none me-2">
            <span class="badge bg-secondary">
                $ {{ usd_rate|number_format(2) }}₴
            </span>

            <span class="badge bg-warning text-dark">
                ₿ {{ btc_price|number_format(0, '.', ',') }}$
            </span>
        </div>

        {# Burger button #}
        <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav"
                aria-controls="navbarNav"
                aria-expanded="false"
                aria-label="Toggle navigation"
        >
            <span class="navbar-toggler-icon"></span>
        </button>

        {# Navbar content #}
        <div class="collapse navbar-collapse" id="navbarNav">

            {# LEFT MENU #}
            <div class="navbar-nav me-auto">

                <a class="nav-link"
                   href="{{ path('app_article_index') }}">
                    Всі статті
                </a>

                {% for category in categories %}
                    <a class="nav-link"
                       href="{{ path('app_category_show', {
                           slug: category.slug
                       }) }}">
                        {{ category.name }}
                    </a>
                {% endfor %}
            </div>

            {# Desktop rates #}
            <div class="d-none d-lg-flex align-items-center gap-2 me-3">
                <span class="badge bg-secondary">
                    $ {{ usd_rate|number_format(2) }}₴
                </span>

                <span class="badge bg-warning text-dark">
                    ₿ {{ btc_price|number_format(0, '.', ',') }}$
                </span>
            </div>

            {# AUTH #}
            <div class="navbar-nav mt-3 mt-lg-0">

                {% if app.user %}

                    <span class="nav-link text-white me-2">
                        {{ app.user.userIdentifier }}
                    </span>

                    <a class="btn btn-outline-light btn-sm"
                       href="{{ path('app_logout') }}">
                        Вийти
                    </a>

                {% else %}

                    <a class="btn btn-outline-light btn-sm me-2 mb-2 mb-lg-0"
                       href="{{ path('app_login') }}">
                        Увійти
                    </a>

                    <a class="btn btn-light btn-sm"
                       href="{{ path('app_register') }}">
                        Реєстрація
                    </a>

                {% endif %}

            </div>

        </div>
    </div>
</nav>

{# MAIN CONTENT #}
<main class="container my-4 flex-grow-1">

    {# Flash messages #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">
            {{ message }}

            <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show">
            {{ message }}

            <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    {% endfor %}

    {% for message in app.flashes('verify_email_error') %}
        <div class="alert alert-warning alert-dismissible fade show">
            {{ message }}

            <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    {% endfor %}

    {% block body %}{% endblock %}
</main>

{# FOOTER #}
<footer class="bg-dark text-white text-center py-3 mt-auto">
    <div class="container">
        <p class="mb-0">
            © {{ "now"|date("Y") }} NewsHub
        </p>
    </div>
</footer>

{# Bootstrap JS #}
<script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
</script>

{% block javascripts %}{% endblock %}

</body>
</html>