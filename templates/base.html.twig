<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}NewsHub{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">NewsHub</a>
        <div class="navbar-nav">
            <a class="nav-link" href="{{ path('app_article_index') }}">Всі статті</a>
            {% for category in categories %}
                <a class="nav-link" href="{{ path('app_category_show', {slug: category.slug}) }}">
                    {{ category.name }}
                </a>
            {% endfor %}
        </div>
    </div>
</nav>

<div class="container">
    {% block body %}{% endblock %}
</div>

<footer class="bg-dark text-white text-center py-3 mt-5">
    <p class="mb-0">© {{ "now"|date("Y") }} NewsHub</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>